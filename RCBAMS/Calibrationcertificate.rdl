    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Select InstrumentValues,Unit,Error,AcceptableError  from CalibrateValues
inner join InstrumentMaster on CalibrateValues.InstrumentID=InstrumentMaster.InstrumentID
inner join CalibrationHistory on CalibrationHistory.CalibrateHistoryID=CalibrateValues.CalibrateHistoryID
where  ValueStatus='Active'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="InstrumentValues">
          <DataField>InstrumentValues</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Unit">
          <DataField>Unit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Error">
          <DataField>Error</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AcceptableError">
          <DataField>AcceptableError</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet3">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct Name,Rank,Designation,MobileNo from CalibrationEngineerMaster 
inner join CalibrationHistory on CalibrationHistory.CalibratedByID=CalibrationEngineerMaster.EngineerID
inner join InstrumentMaster on CalibrationHistory.InstrumentID=InstrumentMaster.InstrumentID
where (CalibrationHistory.Status='Active' or CalibrationHistory.Status=null) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Rank">
          <DataField>Rank</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Designation">
          <DataField>Designation</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MobileNo">
          <DataField>MobileNo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet4">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct Name,Rank,Designation,MobileNo from ApprovingAurhorityMaster 
inner join CalibrationHistory on CalibrationHistory.ApprovingAuthorityID=ApprovingAurhorityMaster.ApproverID
inner join InstrumentMaster on CalibrationHistory.InstrumentID=InstrumentMaster.InstrumentID
where (CalibrationHistory.Status='Active' or CalibrationHistory.Status=null) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
