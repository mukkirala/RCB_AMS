  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>Select InstrumentName,Range,SerialNumber,BrandOrMake,UserSection,NextCalibrationDate,CalibrationHisDate,BodyCondition,MissingParts,InsInspected,CertificateNo,
InsDismantled,Lubricated,InsCaliRange,AssessedBy,CalibrationStatus,Observation from InstrumentMaster
inner join CalibrationHistory on CalibrationHistory.InstrumentID=InstrumentMaster.InstrumentID where (CalibrationHistory.Status='Active' or CalibrationHistory.Status=null)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
