  <div class="table-responsive">
 
    <%--  <dx:ASPxGridView ID="Grid" runat="server" AutoGenerateColumns="False" KeyFieldName="ANLN1" Theme="BlackGlass" CssFilePath="~/App_Themes/PlasticBlue/{0}/styles.css" CssPostfix="PlasticBlue">
        <Columns>
