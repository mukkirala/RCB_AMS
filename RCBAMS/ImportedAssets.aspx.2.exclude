<asp:Content ID="Content1" ContentPlaceHolderID="head" Runat="Server">
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="HeadContent" Runat="Server">
  <script type="text/javascript">
        function CloseGridLookup() {
            gridLookup.ConfirmCurrentSelection();
            gridLookup.HideDropDown();
            gridLookup.Focus();
        }
    </script>
</asp:Content>
<asp:Content ID="Content3" ContentPlaceHolderID="MainContent" Runat="Server">
    <div class="col-sm-12">
 <div>
    <strong>Newly Imported Assets</strong>
</div>
 <br />
  <div class="row form_div">
         <div class="col-sm-2">
            Asset Class Code :<span class="style5"><strong>*</strong></span>
         </div>
         <div class="col-sm-4">
               <%-- <dx:ASPxTextBox ID="txt_assgrpcode" runat="server" Width="170px" 
                    MaxLength="8">
                </dx:ASPxTextBox> --%>
                <%-- <dx:ASPxComboBox ID="cmb_class" runat="server" Height="25px" Width="230px" IncrementalFilteringMode="StartsWith" TextFormatString="{0}"  TextField="AssetClassName" ValueField="AssetClassCode" DataSourceID="SqlDSAssetGroup" ValueType="System.String" CssFilePath="~/App_Themes/PlasticBlue/{0}/styles.css" CssPostfix="PlasticBlue" SpriteCssFilePath="~/App_Themes/PlasticBlue/{0}/sprite.css">
                    <LoadingPanelImage Url="~/App_Themes/PlasticBlue/Editors/Loading.gif">
                    </LoadingPanelImage>
                  
                </dx:ASPxComboBox>--%>
            

       <dx:ASPxGridLookup ID="cmb_class" runat="server" SelectionMode="Multiple" Width="230px" Height="25px"  DataSourceID="SqlDSAssetGroup" ClientInstanceName="gridLookup"
        KeyFieldName="AssetClassCode"  TextFormatString="{0}" MultiTextSeparator=", " Caption="Select Class" AllowUserInput="False">
           <%--<GridViewProperties>
<SettingsBehavior AllowFocusedRow="True" AllowSelectSingleRowOnly="False"></SettingsBehavior>
</GridViewProperties>--%>
        <Columns>
            <dx:GridViewCommandColumn ShowSelectCheckbox="True" />
            <dx:GridViewDataColumn FieldName="AssetClassCode" Settings-AllowAutoFilter="False" Visible="false" />
            <dx:GridViewDataColumn FieldName="AssetClassName" Settings-AllowAutoFilter="True" />
        </Columns>
        <GridViewProperties>
            <Templates>
                <StatusBar>
                    <table class="OptionsTable" style="float: right">
                        <tr>
                            <td>
                                <dx:ASPxButton ID="Close" runat="server" AutoPostBack="false" Text="Close" ClientSideEvents-Click="CloseGridLookup" />
                            </td>
                        </tr>
                    </table>
                </StatusBar>
            </Templates>
            <Settings ShowFilterRow="True" ShowStatusBar="Visible" />
            <SettingsPager PageSize="7" />
        </GridViewProperties>
    </dx:ASPxGridLookup>
                 <asp:SqlDataSource ID="SqlDSAssetGroup" runat="server" 
                        ConnectionString="<%$ ConnectionStrings:RCBSAPConnectionString %>" 
                        SelectCommand="SELECT [AssetClassID],[AssetClassName],[AssetClassCode] FROM [AssetClassMaster]">
                </asp:SqlDataSource>
         </div>
         <div class="clearfix"></div>
  </div>
 <br />
  <div class="row form_div">
         <div class="col-sm-2">        
         </div>
         <div class="col-sm-4">
            <dx:ASPxButton ID="ASPxButton1" runat="server" Text="Import Assets From SAP Database" OnClick="ASPxButton1_Click" CssFilePath="~/App_Themes/SoftOrange/{0}/styles.css" CssPostfix="SoftOrange" SpriteCssFilePath="~/App_Themes/SoftOrange/{0}/sprite.css">
            <ClientSideEvents Click="function(s, e) {  lpanel.Show(); e.processOnServer = true;}"></ClientSideEvents> 
            </dx:ASPxButton><br /><br />               
              <dx:ASPxLoadingPanel runat="server" Modal="True" Text="Please wait" ClientInstanceName="lpanel" ID="ASPxLoadingPanel1">
                 </dx:ASPxLoadingPanel>                
         </div>
         <div class="clearfix"></div>
  </div> 
  <br />
   <div>
    <strong>Assets from SAP</strong>
   </div>
  <br />
