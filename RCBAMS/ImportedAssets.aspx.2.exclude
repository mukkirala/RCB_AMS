                 <PropertiesDateEdit DisplayFormatString="dd-MM-yyyy">
                </PropertiesDateEdit>
            </dx:GridViewDataDateColumn>
            <dx:GridViewDataDateColumn FieldName="ZUGDT" VisibleIndex="7">
                 <PropertiesDateEdit DisplayFormatString="dd-MM-yyyy">
                </PropertiesDateEdit>
            </dx:GridViewDataDateColumn>
            <dx:GridViewDataTextColumn FieldName="PERNR" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            
            <dx:GridViewDataTextColumn FieldName="ORD42" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            <dx:GridViewDataTextColumn FieldName="ORD44" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            <dx:GridViewDataTextColumn FieldName="LOC_DESC" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
             <dx:GridViewDataTextColumn FieldName="STAT_DESC" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
             <dx:GridViewDataTextColumn FieldName="ANLKL" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            <dx:GridViewDataTextColumn FieldName="ORD43" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            <dx:GridViewDataTextColumn FieldName="COMP_DESC" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
            <dx:GridViewDataDateColumn FieldName="DEAKT" VisibleIndex="7">
                 <PropertiesDateEdit DisplayFormatString="dd-MM-yyyy">
                </PropertiesDateEdit>
            </dx:GridViewDataDateColumn>
            <dx:GridViewDataDateColumn FieldName="IVDAT" VisibleIndex="7">
                 <PropertiesDateEdit DisplayFormatString="dd-MM-yyyy">
                </PropertiesDateEdit>
            </dx:GridViewDataDateColumn>
            <dx:GridViewDataTextColumn FieldName="INVZU" VisibleIndex="7">
            </dx:GridViewDataTextColumn>
