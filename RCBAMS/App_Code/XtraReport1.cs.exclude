                   brow.Cells.Add(bc1);
                   XRTableCell bc2 = new XRTableCell();
                   //bc2.TextAlignment= DevExpress.XtraPrinting.TextAlignment.TopRight;
                   bc2.Width = 100;
                   bc2.Text = TGP1.ToString("n2");
                   brow.Cells.Add(bc2);
                   xrDisplayTable.Rows.Add(brow);
                   xrlblTotalDisplayCharge.Text = TGP1.ToString("n2");

