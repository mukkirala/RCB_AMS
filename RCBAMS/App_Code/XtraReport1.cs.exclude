        public XtraReport1( DataSet ds1, DataTable dt, DataSet ds3,String Fname,String Lname,String ClientCompanyName,String ClientAddress, String ClientCity, String ClientState, String Subject)
        {
               InitializeComponent();

               Decimal TGP1 = 0;
               Decimal TGP2 = 0;
               Decimal TGP3 = 0;

               xrPictureBox1.ImageUrl = WebConfigurationManager.AppSettings.Get("Prakashlogo").ToString();

               xrDate.Text = System.DateTime.Today.Date.ToString("dd-MM-yyyy");
               xrVDate.Text = System.DateTime.Today.AddDays(30).Date.ToString("dd-MM-yyyy");
               xrlblSub.Text = Subject;
               xrName.Text = Fname + " " + Lname;
               xrCompanyName.Text = ClientCompanyName;
               xrAddress1.Text = ClientAddress;
               xrCity.Text = ClientCity + "  " + ClientState;
               xrState.Text = "India";
               if (ds1.Tables[0].Rows.Count > 0)
               {

                   for (int i = 0; i < ds1.Tables[0].Rows.Count; i++)
                   {
                       XRTableRow row = new XRTableRow();

                       XRTableCell c1 = new XRTableCell();
                       c1.WidthF = 112F;
                       c1.Text = ds1.Tables[0].Rows[i].ItemArray[0].ToString();
                       row.Cells.Add(c1);
                       XRTableCell c2 = new XRTableCell();
                       c2.WidthF = 195F;
                       c2.Text = ds1.Tables[0].Rows[i].ItemArray[1].ToString();

                       row.Cells.Add(c2);
                       XRTableCell c3 = new XRTableCell();
                       c3.WidthF = 90F;
                       c3.Text = ds1.Tables[0].Rows[i].ItemArray[2].ToString();

                       row.Cells.Add(c3);
                       XRTableCell c4 = new XRTableCell();
                       c4.WidthF = 52F;
                       c4.Text = ds1.Tables[0].Rows[i].ItemArray[3].ToString();

                       row.Cells.Add(c4);
                       XRTableCell c5 = new XRTableCell();
                       c5.WidthF = 50F;
                       c5.Text = ds1.Tables[0].Rows[i].ItemArray[4].ToString();

                       row.Cells.Add(c5);
                       XRTableCell c6 = new XRTableCell();
                       c6.WidthF = 50f;
                       c6.Text = ds1.Tables[0].Rows[i].ItemArray[5].ToString();

                       row.Cells.Add(c6);
                       XRTableCell c7 = new XRTableCell();
                       if (ds1.Tables[0].Rows[i].ItemArray[6] != null)
                       {
                           c7.Text = (ds1.Tables[0].Rows[i].ItemArray[6]).ToString();
                       }
                       c7.WidthF = 83f;
                       row.Cells.Add(c7);
                       XRTableCell c8 = new XRTableCell();
                       c8.Text = ds1.Tables[0].Rows[i].ItemArray[7].ToString();
                       c8.WidthF = 80f;
                       row.Cells.Add(c8);
                       XRTableCell c9 = new XRTableCell();

                       int days = Convert.ToInt32(ds1.Tables[0].Rows[i].ItemArray[8].ToString());
                       decimal TotalPrice = ((Convert.ToDecimal(c8.Text) / 30) * days);
                       c9.WidthF = 60f;
                       c9.Text = days.ToString();
                       row.Cells.Add(c9);
                       XRTableCell c10 = new XRTableCell();
                       c10.Text = Math.Round(TotalPrice, 2).ToString();
                       c10.WidthF = 100f;
                       row.Cells.Add(c10);
                       xrDisplayTable.Rows.Add(row);


                       TGP1 += Convert.ToDecimal(TotalPrice);
                   }
                   XRTableRow brow = new XRTableRow();
                   brow.BackColor = System.Drawing.Color.Silver;
                   XRTableCell bc1 = new XRTableCell();
                   bc1.Width = 770;
